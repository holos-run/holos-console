#!/usr/bin/env bash
# Capture visual verification screenshots for a PR.
#
# Starts a per-agent backend via scripts/agent-dev (SIGPIPE cleanup),
# logs in, and either:
#   (a) runs the PR-specific capture script at scripts/pr-<N>/capture, or
#   (b) navigates to --url <path> and saves a single screenshot.png
#
# Prerequisites:
#   - Kubernetes cluster running (only needed by capture scripts that apply fixtures)
#   - TLS certs generated (make certs)
#
# Usage:
#   scripts/browser-capture-pr <PR-number>
#     Requires scripts/pr-<N>/capture to exist.
#
#   scripts/browser-capture-pr <PR-number> --url /some/path
#     Navigates to the given path and saves docs/screenshots/pr-<N>/screenshot.png.
#     No capture script needed.
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: $0 <PR-number> [--url /path]" >&2
  exit 1
fi

PR_NUMBER="$1"
shift

URL_PATH=""
if [[ $# -ge 2 && "$1" == "--url" ]]; then
  URL_PATH="$2"
  shift 2
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"

CAPTURE_SCRIPT="$SCRIPT_DIR/pr-${PR_NUMBER}/capture"

# Require either a capture script or --url
if [[ -z "$URL_PATH" && ! -x "$CAPTURE_SCRIPT" ]]; then
  echo "ERROR: no capture script found at $CAPTURE_SCRIPT and --url was not given." >&2
  echo "  Create $CAPTURE_SCRIPT or pass --url /path to capture a single page." >&2
  exit 1
fi

DEST_DIR="$REPO_ROOT/docs/screenshots/pr-${PR_NUMBER}"
mkdir -p "$DEST_DIR"

# Start server, capture, and clean up via pipe break.
"$SCRIPT_DIR/agent-dev" | {
  eval "$(head -1)"
  export HOLOS_BACKEND_PORT=$BACKEND_PORT
  export HOLOS_BACKEND_URL="https://localhost:$BACKEND_PORT"
  export PR_SCREENSHOT_DIR="$DEST_DIR"

  echo "==> Server on backend=$BACKEND_PORT"

  # Clear stale OIDC session tokens. Each agent-dev start has a different
  # origin (port-based) so sessionStorage tokens don't carry across ports.
  # Clearing avoids stale-origin confusion; the Dex auto-connector handles
  # fresh login without cookies via the profile page Sign In flow.
  agent-browser --session-name holos-dev eval "sessionStorage.clear()" 2>/dev/null || true

  # Login against the backend (serves the built frontend)
  HOLOS_LOGIN_URL="$HOLOS_BACKEND_URL" "$SCRIPT_DIR/browser-login"

  if [[ -n "$URL_PATH" ]]; then
    # Simple mode: navigate to URL and capture a single screenshot
    AB="agent-browser --session-name holos-dev"
    FULL_URL="$HOLOS_BACKEND_URL$URL_PATH"
    echo "==> Navigating to $FULL_URL"
    $AB open "$FULL_URL"
    $AB wait --load networkidle
    $AB wait 2000
    DEST="$DEST_DIR/screenshot.png"
    $AB screenshot "$DEST"
    echo "Screenshot saved to $DEST"
  else
    # PR-specific capture script
    "$CAPTURE_SCRIPT"
  fi

  echo "Done. Screenshots in $DEST_DIR/"
}
# Pipe closes here → SIGPIPE → agent-dev EXIT trap kills server.
