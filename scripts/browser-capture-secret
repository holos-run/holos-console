#!/usr/bin/env bash
# Capture a screenshot of a secret detail page.
#
# Usage: scripts/browser-capture-secret [URL] [--session-name NAME]
#   Default URL: https://localhost:5173/projects/local-dev/secrets/test-secret
#   Default session name: holos-dev
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=browser-env
source "$SCRIPT_DIR/browser-env"

URL="${1:-$HOLOS_VITE_URL/projects/local-dev/secrets/test-secret}"
SESSION_NAME="${2:-holos-dev}"
AB="agent-browser --session-name $SESSION_NAME"

SCREENSHOTS_DIR="tmp/screenshots"
mkdir -p "$SCREENSHOTS_DIR"

echo "Navigating to $URL"
$AB open "$URL"
$AB wait --load networkidle
$AB wait 2000

DEST="$SCREENSHOTS_DIR/secret-detail-page.png"
$AB screenshot "$DEST"
echo "Screenshot saved to $DEST"
