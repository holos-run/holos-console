#!/usr/bin/env bash
# generate-cue-schema generates CUE definitions from Go types in api/v1alpha2,
# writing them to the schema_gen.cue file for embedding into the binary.
#
# The output files are committed to the repository so that go build works without
# requiring the cue CLI. Regenerate with: make generate
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"

CUE="$(go env GOPATH)/bin/cue"
if [[ ! -x "$CUE" ]]; then
  echo "error: cue not found at $CUE; run 'make tools' first" >&2
  exit 1
fi

# generate_schema generates CUE schema for a single api package.
# Arguments: <go-package> <output-file>
generate_schema() {
  local PKG="$1"
  local OUTPUT="$2"
  local GEN_DIR="cue.mod/gen/${PKG}"
  local VERSION
  VERSION="$(basename "$PKG")"

  # Stage 1: Generate CUE from Go types.
  "$CUE" get go "$PKG"

  # Stage 2: Process generated files — strip package clauses and cue:generate
  # directives, then combine into a single embeddable file.
  {
    echo "// Code generated by scripts/generate-cue-schema from ${PKG} Go types. DO NOT EDIT."
    echo ""

    # Process files in sorted order for deterministic output.
    for f in $(ls "$GEN_DIR"/*.cue | sort); do
      # Skip the doc-only file (contains only a package clause and comments).
      local basename
      basename="$(basename "$f")"
      if [[ "$basename" == "doc_go_gen.cue" ]]; then
        continue
      fi

      echo "// --- $(basename "$f") ---"
      echo ""
      # Strip: package clause, //cue:generate directive, "Code generated" comment,
      # self-referential unifications (e.g. "string & name" → "string"), and blank
      # lines at top. The self-referential patterns (field & field) are generated by
      # cue get go but are no-ops that trigger version-gated features outside a
      # module context.
      sed \
        -e '/^package /d' \
        -e '/^\/\/cue:generate /d' \
        -e '/^\/\/ Code generated by cue get go\. DO NOT EDIT\.$/d' \
        "$f" \
        | sed -E 's/ & [a-zA-Z_][a-zA-Z_0-9]*\??( +@go)/ \1/g' \
        | sed '/./,$!d'
      echo ""
    done
  } > "$OUTPUT"

  echo "wrote $OUTPUT"
}

BASE="github.com/holos-run/holos-console/api"
generate_schema "${BASE}/v1alpha2" "api/v1alpha2/schema_gen.cue"
