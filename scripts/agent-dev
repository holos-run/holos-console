#!/bin/bash
# Start per-agent dev servers on isolated ports.
#
# Derives the agent slot from the working directory (e.g., agent-2 → slot 2)
# and assigns deterministic ports: backend = 9000+slot, vite = 10000+slot.
#
# Lifecycle: prints BACKEND_PORT and VITE_PORT assignments to stdout, then
# enters a heartbeat loop. When the reading end of the pipe closes (reader
# exits), the next write raises SIGPIPE, which terminates this script. The
# EXIT trap kills both child servers. This is the most reliable cleanup
# pattern — no PID files, no stale processes.
#
# Usage:
#   scripts/agent-dev | {
#     eval "$(head -2)"
#     export HOLOS_BACKEND_PORT=$BACKEND_PORT
#     export HOLOS_VITE_PORT=$VITE_PORT
#     scripts/browser-login
#     scripts/browser-capture-pr-200
#   }
#
# When the { ... } block exits, the pipe breaks and servers are cleaned up.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

cd "$PROJECT_ROOT"

# --- Derive agent slot from working directory ---
# Matches "agent-N" in the path; falls back to slot 0 for manual use.
SLOT=0
if [[ "$PWD" =~ agent-([0-9]+) ]]; then
  SLOT="${BASH_REMATCH[1]}"
fi

BACKEND_PORT=$((9000 + SLOT))
VITE_PORT=$((10000 + SLOT))

# --- Build ---
make build >&2

# --- Cleanup trap ---
BACKEND_PID=""
VITE_PID=""

cleanup() {
  [[ -n "$VITE_PID" ]] && kill "$VITE_PID" 2>/dev/null || true
  [[ -n "$BACKEND_PID" ]] && kill "$BACKEND_PID" 2>/dev/null || true
  wait 2>/dev/null || true
}
trap cleanup EXIT

# --- Start backend ---
exec ./bin/holos-console \
  --enable-insecure-dex \
  --cert certs/tls.crt \
  --key certs/tls.key \
  --ca-cert "$(mkcert -CAROOT)/rootCA.pem" \
  --listen ":$BACKEND_PORT" \
  >"$PROJECT_ROOT/tmp/agent-dev-backend.log" 2>&1 &
BACKEND_PID=$!

# Wait for backend readiness
for _ in $(seq 1 30); do
  if curl -sk "https://localhost:$BACKEND_PORT/healthz" >/dev/null 2>&1; then
    break
  fi
  sleep 1
done

if ! curl -sk "https://localhost:$BACKEND_PORT/healthz" >/dev/null 2>&1; then
  echo "ERROR: backend did not become ready on port $BACKEND_PORT" >&2
  exit 1
fi
echo "Backend ready on port $BACKEND_PORT" >&2

# --- Start Vite dev server ---
HOLOS_BACKEND_PORT="$BACKEND_PORT" HOLOS_VITE_PORT="$VITE_PORT" \
  npm --prefix "$PROJECT_ROOT/frontend" run dev -- --port "$VITE_PORT" \
  >"$PROJECT_ROOT/tmp/agent-dev-vite.log" 2>&1 &
VITE_PID=$!

for _ in $(seq 1 30); do
  if curl -sk "https://localhost:$VITE_PORT/" >/dev/null 2>&1; then
    break
  fi
  sleep 1
done

if ! curl -sk "https://localhost:$VITE_PORT/" >/dev/null 2>&1; then
  echo "ERROR: vite did not become ready on port $VITE_PORT" >&2
  exit 1
fi
echo "Vite ready on port $VITE_PORT" >&2

# --- Output port assignments (consumed by pipe reader) ---
echo "BACKEND_PORT=$BACKEND_PORT"
echo "VITE_PORT=$VITE_PORT"

# --- Heartbeat loop: SIGPIPE kills us when pipe reader exits ---
while sleep 2; do
  echo "# heartbeat" || exit 0
done
