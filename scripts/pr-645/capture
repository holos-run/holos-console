#!/bin/bash
# Capture screenshots for PR #645: remove -k/-insecure TLS flags
# Shows the profile page API Access section and deployment detail page Template tab
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/../.." && pwd)"

# Source browser environment
source "${ROOT_DIR}/scripts/browser-env"

mkdir -p "${PR_SCREENSHOT_DIR}"

# Capture profile page API Access section
agent-browser navigate "${HOLOS_BACKEND_URL}/profile"
agent-browser screenshot "${PR_SCREENSHOT_DIR}/profile-api-access.png"

echo "Screenshots saved to ${PR_SCREENSHOT_DIR}"
