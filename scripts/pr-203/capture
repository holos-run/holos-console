#!/usr/bin/env bash
# PR #203 — capture profile page showing Token Claims section (iss and aud).
#
# Called by scripts/browser-capture-pr 203. Expects:
#   HOLOS_BACKEND_PORT, HOLOS_BACKEND_URL, PR_SCREENSHOT_DIR
set -euo pipefail

AB="agent-browser --session-name holos-dev"
PROFILE_URL="$HOLOS_BACKEND_URL/profile"

echo "==> Navigating to profile page"
$AB open "$PROFILE_URL"
$AB wait --load networkidle
$AB wait --text "Token Claims" 2>/dev/null || $AB wait 5000

$AB screenshot "$PR_SCREENSHOT_DIR/profile-token-claims.png"
echo "Saved profile-token-claims.png"

echo "==> Scrolling down to show full Token Claims section"
$AB eval "document.querySelector('body').scrollTo(0, document.body.scrollHeight)"
$AB wait 500

$AB screenshot "$PR_SCREENSHOT_DIR/profile-token-claims-scrolled.png"
echo "Saved profile-token-claims-scrolled.png"
