#!/usr/bin/env bash
# Capture visual verification screenshots for PR #200.
#
# Starts a per-agent backend via scripts/agent-dev (SIGPIPE cleanup),
# applies K8s fixtures, logs in, and captures read-mode and edit-mode
# screenshots of the sharing panel with no time bounds set.
#
# Prerequisites:
#   - Kubernetes cluster running (e.g., k3d)
#   - TLS certs generated (make certs)
#
# Usage: scripts/browser-capture-pr-200
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"

DEST_DIR="$REPO_ROOT/docs/screenshots/pr-200"
mkdir -p "$DEST_DIR"

# Apply K8s fixtures
kubectl apply -f "$REPO_ROOT/frontend/e2e/fixtures/project-namespace.yaml" \
              -f "$REPO_ROOT/frontend/e2e/fixtures/secret-no-time-bounds.yaml"

# Start server, capture, and clean up via pipe break.
"$SCRIPT_DIR/agent-dev" | {
  eval "$(head -1)"
  export HOLOS_BACKEND_PORT=$BACKEND_PORT

  echo "==> Server on backend=$BACKEND_PORT"

  # Login against the backend (serves the built frontend)
  "$SCRIPT_DIR/browser-login"

  AB="agent-browser --session-name holos-dev"
  SECRET_URL="https://localhost:$BACKEND_PORT/projects/time-test/secrets/no-time-bounds"

  echo "==> Navigating to secret detail page (read mode)"
  $AB open "$SECRET_URL"
  $AB wait --load networkidle
  $AB wait --text "Sharing" 2>/dev/null || $AB wait 5000

  $AB screenshot "$DEST_DIR/read-mode-no-time-bounds.png"
  echo "Saved read-mode-no-time-bounds.png"

  echo "==> Clicking Sharing Edit button to enter edit mode"
  $AB eval "
    const buttons = [...document.querySelectorAll('button')];
    const editBtns = buttons.filter(b => b.textContent.trim() === 'Edit');
    if (editBtns.length > 0) editBtns[editBtns.length - 1].click();
  "
  $AB wait 1000

  $AB screenshot "$DEST_DIR/edit-mode-set-buttons.png"
  echo "Saved edit-mode-set-buttons.png"

  echo "Done. Screenshots in $DEST_DIR/"
}
# Pipe closes here → SIGPIPE → agent-dev EXIT trap kills server.
